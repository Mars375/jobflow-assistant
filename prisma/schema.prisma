generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  password      String    // Bcrypt hash
  name          String?

  // Email verification
  emailVerified DateTime?

  // GDPR tracking
  gdprConsentedAt          DateTime?
  consentedToPrivacyPolicy Boolean @default(false)

  // Session management
  sessions      Session[]

  // Phase 2 - CV and jobs
  cvs           UserCv[]
  profile       UserProfile?
  jobStates     UserJobState[]
  jobFilter     UserJobFilter?

  // Phase 4 - Applications
  applications  JobApplication[]

  // Phase 5 - Alerts & notifications
  notifications UserNotification?
  sentAlerts    SentAlert[]

  // GDPR tracking
  deletionRequests DeletionRequest[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete option

  @@index([email])
}

enum ApplicationStatus {
  BROUILLON
  EN_ATTENTE
  ENTRETIEN
  OFFRE
  REFUSE
}

enum AlertType {
  EMAIL_DIGEST
  SLACK_REALTIME
  TELEGRAM_REALTIME
}

model UserCv {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName      String
  mimeType      String
  sizeBytes     Int
  storagePath   String
  rawText       String?
  parsedAt      DateTime?
  parseWarnings Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, isActive])
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         Json
  experience     Json
  education      Json
  contact        Json
  embedding      Unsupported("vector(1536)")?
  lastReviewedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model JobPosting {
  id           String    @id @default(cuid())
  source       String
  sourceId     String
  title        String
  company      String?
  location     String?
  contractType String?
  description  String?
  salaryText   String?
  publishedAt  DateTime?
  fetchedAt    DateTime
  url          String?
  metadata     Json?
  embedding    Unsupported("vector(1536)")?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  userStates   UserJobState[]
  applications JobApplication[]
  sentAlerts   SentAlert[]

  @@unique([source, sourceId])
  @@index([publishedAt])
}

model UserNotification {
  id                 String   @id @default(cuid())
  userId             String   @unique
  emailDigestEnabled Boolean  @default(true)
  emailDigestLastSent DateTime?
  timezone           String   @default("Europe/Paris")
  slackWebhookUrl    String?
  telegramChatId     String?
  dailyAlertsCount   Int      @default(0)
  dailyAlertsResetAt DateTime @default(now())
  lastAlertSentAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dailyAlertsResetAt])
}

model SentAlert {
  id        String    @id @default(cuid())
  userId    String
  jobId     String
  alertType AlertType
  sentAt    DateTime  @default(now())
  createdAt DateTime  @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId, alertType])
  @@index([userId, sentAt])
}

model JobApplication {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobPostingId  String?
  jobPosting    JobPosting?       @relation(fields: [jobPostingId], references: [id], onDelete: SetNull)

  company       String
  roleTitle     String
  status        ApplicationStatus

  appliedAt     DateTime          @default(now())
  firstResponseAt DateTime?

  notes         String?
  offerUrl      String?
  source        String?

  contactName   String?
  contactEmail  String?
  contactPhone  String?
  salaryText    String?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId, status])
  @@index([userId, company])
  @@index([userId, appliedAt])
}

model UserJobState {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)
  firstSeenAt DateTime  @default(now())
  seenAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, jobId])
  @@index([userId, seenAt])
}

model UserJobFilter {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword      String?
  location     String?
  contractType String?
  updatedAt    DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique // Refresh token (hashed)
  expiresAt    DateTime

  createdAt    DateTime @default(now())

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DeletionRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  completed Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

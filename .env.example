# Database (from Neon Dashboard → Connection Details → Connection string)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# Token Security (generate with: openssl rand -base64 32)
TOKEN_SECRET=""

# Upstash Redis (from Vercel Marketplace → Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend Email (from Resend Dashboard → API Keys)
RESEND_API_KEY=""

# Cron auth for internal endpoints (generate with: openssl rand -base64 32)
CRON_SECRET=""

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email sender (default uses Resend test domain)
EMAIL_FROM="JobFlow Assistant <onboarding@resend.dev>"

# France Travail API (official jobs API via OAuth2 client credentials)
FRANCE_TRAVAIL_CLIENT_ID=""
FRANCE_TRAVAIL_CLIENT_SECRET=""
FRANCE_TRAVAIL_SCOPE="api_offresdemploiv2 o2dsoffre"

# Adzuna fallback API (optional)
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# Telegram alerts
# Create bot with BotFather. Token stays server-side only.
TELEGRAM_BOT_TOKEN=""
# Bot username (without '@'), e.g. JobFlowAssistantBot
TELEGRAM_BOT_USERNAME=""
# Telegram webhook secret_token header value (generate with: openssl rand -base64 32)
TELEGRAM_WEBHOOK_SECRET=""
